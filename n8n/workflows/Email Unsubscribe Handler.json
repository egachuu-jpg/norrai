{
  "name": "Email Unsubscribe Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "email-unsubscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
