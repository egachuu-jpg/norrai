      "parameters": {
        "jsCode": "const existing_id = $input.first().json.id;\nconst ctx = $('Build Dedupe Query').first().json;\nconst p = ctx.payload;\nconst msg = (p.lead_message || '').replace(/'/g, \"''\");\nreturn [{ json: { query: `UPDATE leads SET lead_message = '${msg}', updated_at = now() WHERE id = '${existing_id}'` } }];"
      },
