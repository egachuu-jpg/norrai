    {
      "parameters": {
        "jsCode": "const ctx = $('Build Dedupe Query').first().json;\nconst p = ctx.payload;\nconst esc = v => (v || '').toString().replace(/'/g, \"''\");\nconst metadata = JSON.stringify({ property_address: p.property_address || null, price_range: p.price_range || null, beds: p.beds || null }).replace(/'/g, \"''\");\nconst today = new Date().toISOString().split('T')[0];\nreturn [{\n  json: {\n    query: `INSERT INTO leads (client_id, lead_name, email, phone, source, lead_message, status, stage, next_action_due, metadata) VALUES ('${ctx.client_id}', '${esc(p.lead_name)}', '${esc(p.email)}', '${esc(p.phone)}', '${esc(p.source)}', '${esc(p.lead_message)}', 'new', 'new', '${today}', '${metadata}') RETURNING id`,\n    client_id: ctx.client_id, agent_email: ctx.agent_email, agent_name: ctx.agent_name,\n    agent_phone: ctx.agent_phone || '', brokerage: ctx.brokerage || '', payload: p\n  }\n}];"
      },
