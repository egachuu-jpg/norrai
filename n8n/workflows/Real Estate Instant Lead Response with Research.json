        "jsCode": "const response = $input.first().json;\nconst message = response.content[0].text.trim();\n\n// Carry through fields from Build Prompt node\nconst prev = $('Build Prompt').first().json;\n\nreturn [{\n  json: {\n    message,\n    lead_name:        prev.lead_name,\n    lead_phone:       prev.lead_phone,\n    lead_email:       prev.lead_email,\n    agent_name:       prev.agent_name,\n    agent_email:      prev.agent_email,\n    property_address: prev.property_address\n  }\n}];"
