    {
      "parameters": {
        "method": "POST",
        "url": "https://norrai.app.n8n.cloud/webhook/research-agent",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-norr-token",
              "value": "8F68D963-7060-4033-BD04-7593E4B203CB"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"address\": \"{{ $json.body.property_street }}\",\n  \"city\": \"{{ $json.body.property_city }}\",\n  \"state\": \"{{ $json.body.property_state }}\",\n  \"zip\": \"{{ $json.body.property_zip }}\",\n  \"price_range\": \"{{ $json.body.price_range }}\",\n  \"beds\": \"{{ $json.body.beds }}\",\n  \"baths\": \"{{ $json.body.baths }}\",\n  \"caller\": \"instant_lead_response\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1056,
        1136
      ],
      "id": "08735dc8-9be3-429d-8dbd-5b8be66ced7d",
      "name": "Call Research Agent",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "let insight_block = '';\nlet research_detail = '';\ntry {\n  const research = $('Call Research Agent').first().json;\n  if (research && research.status === 'ok') {\n    insight_block = research.insight_block || '';\n    const lines = [];\n    if (research.walkability && research.walkability.description) {\n      lines.push(`Walkability: ${research.walkability.description}`);\n    }\n    if (Array.isArray(research.schools) && research.schools.length > 0) {\n      lines.push('Nearby schools:');\n      research.schools.forEach(s => {\n        let entry = `  - ${s.name} (${s.grades})`;\n        if (s.rating) entry += ` — ${s.rating}/10`;\n        if (s.distance_miles) entry += `, ${s.distance_miles} mi away`;\n        lines.push(entry);\n      });\n    }\n    if (research.market) {\n      const m = research.market;\n      const mParts = [];\n      if (m.median_sale_price) mParts.push(`median sale price $${Number(m.median_sale_price).toLocaleString()}`);\n      if (m.median_days_on_market) mParts.push(`avg ${m.median_days_on_market} days on market`);\n      if (m.yoy_price_trend) mParts.push(`${m.yoy_price_trend} YoY`);\n      if (mParts.length) lines.push(`Market: ${mParts.join(' · ')}`);\n    }\n    research_detail = lines.join('\\n');\n  }\n} catch(e) {}\n\nreturn [{ json: { ...$('Validate Input').first().json, insight_block, research_detail } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        1136
      ],
      "id": "4b9e07b4-877a-4c26-9961-873047f49de0",
