    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Required field validation\nconst required = ['lead_name', 'email', 'agent_name', 'agent_email', 'property_address'];\nfor (const field of required) {\n  if (!body[field] || !String(body[field]).trim()) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\n// Email format check\nconst emailRe = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!emailRe.test(body.email)) throw new Error('Invalid lead email format');\nif (!emailRe.test(body.agent_email)) throw new Error('Invalid agent email format');\n\n// Length caps — prevent oversized payloads to Claude\nconst maxLengths = { lead_name: 100, lead_message: 2000, property_address: 200, key_details: 1000 };\nfor (const [field, max] of Object.entries(maxLengths)) {\n  if (body[field] && String(body[field]).length > max) {\n    throw new Error(`Field too long: ${field} (max ${max} chars)`);\n  }\n}\n\nreturn [$input.first()];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        1232
      ],
      "id": "55c58715-e906-4502-919b-0eabc040a638",
