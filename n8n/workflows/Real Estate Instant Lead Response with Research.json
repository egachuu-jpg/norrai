    {
      "parameters": {
        "jsCode": "const client_id = ($input.first().json.id || null);\nif (!client_id) return [{ json: { lead_query: 'SELECT 1' } }];\nconst body = $('Receive Lead').first().json.body;\nconst esc = v => (v || '').toString().replace(/'/g, \"''\");\nconst meta = JSON.stringify({ property_address: body.property_address || null, price_range: body.price_range || null, beds: body.beds || null }).replace(/'/g, \"''\");\nreturn [{ json: { lead_query: `INSERT INTO leads (client_id, lead_name, email, phone, source, lead_message, status, metadata) VALUES ('${client_id}'::uuid, '${esc(body.lead_name)}', '${esc(body.email)}', '${esc(body.phone)}', '${esc(body.source)}', '${esc(body.lead_message)}', 'new', '${meta}'::jsonb)` } }];"
      },
