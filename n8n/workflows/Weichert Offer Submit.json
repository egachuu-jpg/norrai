    {
      "parameters": {
        "jsCode": "const body = $('Receive Offer').first().json.body;\n\nconst offerAmount = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(body.offer_amount || 0);\n\nconst financingLabels = {\n  conventional: 'Conventional (pre-approved)',\n  fha:          'FHA',\n  va:           'VA',\n  cash:         'Cash',\n  other:        'Other',\n};\nconst financing = financingLabels[body.financing_type] || body.financing_type || 'Not specified';\n\nconst contingencies = [\n  body.contingency_inspection   ? 'Inspection'    : null,\n  body.contingency_financing    ? 'Financing'     : null,\n  body.contingency_appraisal    ? 'Appraisal'     : null,\n  body.contingency_sale_of_home ? 'Sale of home'  : null,\n].filter(Boolean);\nconst contingencyText = contingencies.length ? contingencies.join(', ') : 'None';\n\nconst closeDate = body.proposed_close_date\n  ? new Date(body.proposed_close_date + 'T12:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })\n  : 'Not specified';\n\nconst mlsLink = body.listing_url\n  ? `<a href=\"${body.listing_url}\" style=\"color: #7FA9B8;\">${body.listing_url}</a>`\n  : 'Not provided';\n\nconst buyerNotesHtml = body.buyer_notes\n  ? `<p style=\"font-size: 13px; color: #3A3F48; padding: 12px 14px; background: #FAFAF7; border-radius: 6px; border: 1px solid #E5E4DE; margin: 0;\">${body.buyer_notes}</p>`\n  : '<p style=\"font-size: 13px; color: #9EA3AA; margin: 0;\">No notes provided.</p>';\n\nconst emailHtml = [\n  '<div style=\"font-family: \\'Inter\\', Arial, sans-serif; max-width: 560px; margin: 0 auto; color: #0A0F1A;\">',\n  '  <div style=\"background: #0A0F1A; padding: 32px 32px 28px; border-radius: 8px 8px 0 0;\">',\n  '    <p style=\"font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #7FA9B8; margin: 0 0 10px;\">Offer Interest · Weichert Realty</p>',\n  '    <h1 style=\"font-size: 22px; font-weight: 700; color: #FAFAF7; margin: 0; letter-spacing: -0.02em;\">New offer interest received.</h1>',\n  '  </div>',\n  '  <div style=\"background: #FFFFFF; padding: 32px; border: 1px solid #E5E4DE; border-top: none; border-radius: 0 0 8px 8px;\">',\n  '',\n  '    <p style=\"font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #7FA9B8; margin: 0 0 4px;\">Property</p>',\n  '    <p style=\"font-size: 16px; font-weight: 600; color: #0A0F1A; margin: 0 0 20px;\">' + (body.property_address || 'Unknown') + '</p>',\n  '',\n  '    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">',\n  '      <tr>',\n  '        <td style=\"width: 50%; padding: 12px 14px; background: #FAFAF7; border: 1px solid #E5E4DE; vertical-align: top;\">',\n  '          <p style=\"font-size: 11px; color: #9EA3AA; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.1em;\">Offer Amount</p>',\n  '          <p style=\"font-size: 18px; font-weight: 700; color: #0A0F1A; margin: 0;\">' + offerAmount + '</p>',\n  '        </td>',\n  '        <td style=\"width: 50%; padding: 12px 14px; background: #FAFAF7; border: 1px solid #E5E4DE; border-left: none; vertical-align: top;\">',\n  '          <p style=\"font-size: 11px; color: #9EA3AA; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.1em;\">Financing</p>',\n  '          <p style=\"font-size: 15px; font-weight: 600; color: #0A0F1A; margin: 0;\">' + financing + '</p>',\n  '        </td>',\n  '      </tr>',\n  '      <tr>',\n  '        <td style=\"padding: 12px 14px; background: #FAFAF7; border: 1px solid #E5E4DE; border-top: none; vertical-align: top;\">',\n  '          <p style=\"font-size: 11px; color: #9EA3AA; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.1em;\">Proposed Close Date</p>',\n  '          <p style=\"font-size: 15px; font-weight: 600; color: #0A0F1A; margin: 0;\">' + closeDate + '</p>',\n  '        </td>',\n  '        <td style=\"padding: 12px 14px; background: #FAFAF7; border: 1px solid #E5E4DE; border-top: none; border-left: none; vertical-align: top;\">',\n  '          <p style=\"font-size: 11px; color: #9EA3AA; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.1em;\">Contingencies</p>',\n  '          <p style=\"font-size: 15px; font-weight: 600; color: #0A0F1A; margin: 0;\">' + contingencyText + '</p>',\n  '        </td>',\n  '      </tr>',\n  '    </table>',\n  '',\n  '    <p style=\"font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #7FA9B8; margin: 0 0 6px;\">Buyer Info</p>',\n  '    <p style=\"font-size: 14px; color: #0A0F1A; margin: 0 0 4px;\"><strong>' + (body.buyer_name || '') + '</strong></p>',\n  '    <p style=\"font-size: 14px; color: #3A3F48; margin: 0 0 4px;\">' + (body.buyer_phone || '') + '</p>',\n  '    <p style=\"font-size: 14px; color: #3A3F48; margin: 0 0 20px;\">' + (body.buyer_email || '') + '</p>',\n  '',\n  '    <p style=\"font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #7FA9B8; margin: 0 0 8px;\">Notes from Buyer</p>',\n  '    ' + buyerNotesHtml,\n  '    <div style=\"margin-top: 24px;\"></div>',\n  '',\n  '    <p style=\"font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #7FA9B8; margin: 0 0 6px;\">MLS Listing</p>',\n  '    <p style=\"font-size: 13px; color: #3A3F48; margin: 0 0 24px; word-break: break-all;\">' + mlsLink + '</p>',\n  '',\n  '    <hr style=\"border: none; border-top: 1px solid #E5E4DE; margin: 0 0 20px;\">',\n  '    <p style=\"font-size: 12px; color: #9EA3AA; margin: 0;\">Norr AI &nbsp;\\u00b7&nbsp; <a href=\"https://norrai.co\" style=\"color: #9EA3AA;\">norrai.co</a></p>',\n  '  </div>',\n  '</div>',\n].join('\\n');\n\nreturn [{\n  json: {\n    email_html:       emailHtml,\n    buyer_name:       body.buyer_name       || '',\n    buyer_email:      body.buyer_email      || '',\n    buyer_phone:      body.buyer_phone      || '',\n    offer_amount:     offerAmount,\n    property_address: body.property_address || '',\n    agent_name:       body.agent_name       || '',\n    agent_email:      body.agent_email      || '',\n  }\n}];"
      },
