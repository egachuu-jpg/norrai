      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_events (client_id, workflow_name, event_type, payload)\nVALUES (\n  '{{ $json.id || \"e2f9934c-4d28-4bb4-ac90-4284c1123517\" }}',\n  'weichert_offer_submit',\n  'triggered',\n  json_build_object(\n    'agent_email',      '{{ $('Receive Offer').first().json.body.agent_email }}',\n    'property_address', '{{ $('Receive Offer').first().json.body.property_address }}'\n  )::jsonb\n)",
