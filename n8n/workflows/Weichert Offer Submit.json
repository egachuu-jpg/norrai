        "jsonBody": "={\n  \"personalizations\": [{\n    \"to\": [\n      {\"email\": \"{{ $json.agent_email }}\", \"name\": \"{{ $json.agent_name }}\"}\n    ]\n  }],\n  \"from\": {\"email\": \"studio@norrai.co\", \"name\": \"Norr AI\"},\n  \"reply_to\": {\"email\": \"{{ $json.buyer_email }}\", \"name\": \"{{ $json.buyer_name }}\"},\n  \"subject\": \"Offer interest: {{ $json.property_address }} \\u2014 {{ $json.offer_amount }}\",\n  \"content\": [{\"type\": \"text/html\", \"value\": {{ JSON.stringify($json.email_html) }}}],\n  \"tracking_settings\": {\"click_tracking\": {\"enable\": false}}\n}",
        "options": {}
