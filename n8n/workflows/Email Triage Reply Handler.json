    {
      "id": "rh-0094-4000-8000-000000000000",
      "name": "Is My Chat?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        440,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "chat-id-check",
              "leftValue": "={{ $json.message.chat.id.toString() }}",
              "rightValue": "8792529492",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "rh-0095-4000-8000-000000000000",
      "name": "Parse Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        200
      ],
      "parameters": {
        "jsCode": "const text = ($input.first().json.message.text ?? '').trim().toLowerCase();\nconst approvedNumbers = text === 'all' ? 'all' : text.split(/\\s+/).map(Number).filter(n => !isNaN(n) && n > 0);\nreturn [{ json: { approvedNumbers, rawText: text } }];"
      }
    },
    {
      "id": "rh-0096-4000-8000-000000000000",
      "name": "Fetch Pending",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        840,
        200
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, message_id, inbox, sender, subject, proposed_action\nFROM email_triage_queue\nWHERE status = 'pending'\nORDER BY created_at ASC",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon Postgres"
        }
      }
    },
    {
      "id": "rh-0097-4000-8000-000000000000",
      "name": "Build Action Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        200
      ],
      "parameters": {
        "jsCode": "const pending = $input.all().map((item, i) => ({ ...item.json, position: i + 1 }));\nconst approved = $('Parse Reply').first().json.approvedNumbers;\nconst toAct  = approved === 'all' ? pending : pending.filter(p => approved.includes(p.position));\nconst toSkip = pending.filter(p => !toAct.find(a => a.id === p.id));\n\nconst verb = { mark_read_archive: 'archived', mark_read: 'marked read', trash: 'trashed', mark_important: 'marked important', queue_for_review: 'reviewed' };\nconst parts = [];\nif (toAct.length)  parts.push(`✓ Done — ${toAct.map(i => `${verb[i.proposed_action] ?? 'actioned'} ${i.position}`).join(', ')}.`);\nif (toSkip.length) parts.push(`Skipped ${toSkip.map(i => i.position).join(', ')}.`);\nconst confirmMsg = parts.join(' ') || '✓ No actions taken.';\n\nreturn [\n  ...toAct.map(i  => ({ json: { ...i, skip: false } })),\n  ...toSkip.map(i => ({ json: { ...i, skip: true  } })),\n  { json: { __is_summary: true, __confirm_msg: confirmMsg } }\n];"
      }
    },
    {
      "id": "rh-0098-4000-8000-000000000000",
      "name": "Loop Over Actions",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1240,
        200
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
