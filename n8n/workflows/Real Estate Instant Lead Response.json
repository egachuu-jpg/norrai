        "contentValue": "=Hi {{ $json.agent_name }},\n\nA lead response was just sent to {{ $json.lead_name }} via email. Here's a copy:\n\n---\n\n{{ $json.message }}\n\n---\n\nLead details:\n- Name: {{ $json.lead_name }}\n- Phone: {{ $json.lead_phone }}\n- Email: {{ $json.lead_email }}\n- Property: {{ $json.property_address }}\n\nNorr AI",
        "additionalFields": {}
