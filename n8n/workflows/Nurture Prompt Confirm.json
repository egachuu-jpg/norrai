    {
      "parameters": {
        "jsCode": "const lead_id = ($('Receive Click').first().json.query.lead_id || '').trim();\nconst uuidRe = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nif (!uuidRe.test(lead_id)) throw new Error('Invalid lead_id format');\nreturn [{ json: {\n  query: `SELECT l.id, l.lead_name, l.email, l.phone, l.source, l.lead_message, l.nurture_enrolled_at, l.metadata, l.client_id, c.primary_contact_name AS agent_name, c.primary_contact_email AS agent_email, c.primary_contact_phone AS agent_phone, c.business_name FROM leads l JOIN clients c ON l.client_id = c.id WHERE l.id = '${lead_id}' LIMIT 1`,\n  lead_id\n} }];"
      },
