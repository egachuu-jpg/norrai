        "jsCode": "const lead = $('Lookup Lead').first().json;\nconst enroll = $('Build Enrollment Payload').first().json;\nreturn [{ json: {\n  update_query: `UPDATE leads SET nurture_enrolled_at = now(), updated_at = now() WHERE id = '${enroll.lead_id}'`,\n  log_query:    `INSERT INTO workflow_events (client_id, workflow_name, event_type, payload) VALUES ('${enroll.client_id}'::uuid, 'nurture_prompt_confirm', 'completed', '{\"lead_id\": \"${enroll.lead_id}\"}'::jsonb)`,\n  lead_name:    lead.lead_name || 'This lead'\n} }];"
