{
  "name": "Manual Opt-Out Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "manual-optout",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [240, 300],
      "id": "mo100001-0001-4000-8000-mo1000000001",
      "name": "Receive Opt-Out",
      "webhookId": "manual-optout-webhook-001"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id FROM clients WHERE token = '{{ $json.body.agent_token }}'",
        "continueOnFail": true
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [460, 300],
      "id": "mo100001-0002-4000-8000-mo1000000002",
      "name": "Verify Token",
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon Postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "mo-token-check",
              "leftValue": "={{ $input.first().json.id }}",
              "operator": {
                "type": "string",
                "operation": "exists",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [680, 300],
      "id": "mo100001-0003-4000-8000-mo1000000003",
      "name": "Token Valid?"
    },
    {
      "parameters": {
        "jsCode": "const phone = ($('Receive Opt-Out').first().json.body.phone || '').replace(/[^\\d]/g, '');\nif (!phone || phone.length < 10) {\n  throw new Error('Invalid phone: ' + phone);\n}\nreturn [{ json: { safe_phone: phone } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 200],
      "id": "mo100001-0004-4000-8000-mo1000000004",
      "name": "Sanitize Phone"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_events (client_id, workflow_name, event_type, payload)\nVALUES (\n  '{{ $('Verify Token').first().json.id }}',\n  'manual_optout_handler',\n  'triggered',\n  jsonb_build_object('execution_id', '{{ $execution.id }}')\n)",
        "continueOnFail": true
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1060, 200],
      "id": "mo100001-0005-4000-8000-mo1000000005",
      "name": "Log Triggered",
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE leads\nSET sms_opt_out = true, opted_out_at = NOW()\nWHERE phone = '{{ $json.safe_phone }}'",
        "continueOnFail": true
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1240, 200],
      "id": "mo100001-0006-4000-8000-mo1000000006",
      "name": "Set SMS Opt-Out",
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_events (client_id, workflow_name, event_type, payload)\nVALUES (\n  '{{ $('Verify Token').first().json.id }}',\n  'manual_optout_handler',\n  'completed',\n  jsonb_build_object(\n    'phone', '{{ $('Receive Opt-Out').first().json.body.phone }}',\n    'execution_id', '{{ $execution.id }}'\n  )\n)",
        "continueOnFail": true
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1420, 200],
      "id": "mo100001-0007-4000-8000-mo1000000007",
      "name": "Log Completed",
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon Postgres"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"ok\": true}",
        "options": {
          "responseCode": 200
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1600, 200],
      "id": "mo100001-0008-4000-8000-mo1000000008",
      "name": "Respond OK"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"ok\": false, \"error\": \"invalid token\"}",
        "options": {
          "responseCode": 401
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 420],
      "id": "mo100001-0009-4000-8000-mo1000000009",
      "name": "Respond Unauthorized"
    }
  ],
