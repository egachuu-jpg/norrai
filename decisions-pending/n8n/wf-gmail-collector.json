    {
      "id": "4f004087-dca2-41ed-9f78-c76260b03b36",
      "name": "Extract Last Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        200
      ],
      "parameters": {
        "jsCode": "const thread = $input.first().json;\nconst messages = thread.messages || [];\nconst last = messages[messages.length - 1] || {};\nconst headerVal = (msg, name) => {\n  const h = (msg.payload && msg.payload.headers) || [];\n  const found = h.find((x) => (x.name || '').toLowerCase() === name);\n  return found ? found.value : (msg[name] || '');\n};\nconst last_message_from = headerVal(last, 'from') || last.From || '';\nconst subject = headerVal(last, 'subject') || last.Subject || thread.snippet || '';\n\nconst truncated = messages.slice(-3).map((m) => ({\n  from: headerVal(m, 'from') || m.From || '',\n  body: ((m.snippet || m.textPlain || m.body || '') + '').slice(0, 2000),\n}));\n\nreturn [{ json: {\n  thread_id: thread.id,\n  subject,\n  last_message_from,\n  messages: truncated,\n} }];"
      }
    },
