    {
      "id": "52d05b01-00f8-4dd9-92ec-46da3088aa69",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        420
      ],
      "parameters": {
        "jsCode": "const raw = ($input.first().json.content && $input.first().json.content[0] && $input.first().json.content[0].text) || '';\nconst thread_id = $('Build Thread Data').first().json.thread_id;\nlet parsed;\nlet parse_ok = true;\ntry {\n  parsed = JSON.parse(raw.trim());\n} catch (e) {\n  parse_ok = false;\n  parsed = { needs_action: false, confidence: 0 };\n}\nreturn [{ json: {\n  parse_ok,\n  thread_id,\n  needs_action: parsed.needs_action ?? false,\n  title: parsed.title ?? null,\n  ask: parsed.ask ?? null,\n  deadline: parsed.deadline ?? null,\n  urgency: parsed.urgency ?? 'normal',\n  confidence: parsed.confidence ?? 0,\n  draft_reply: parsed.draft_reply ?? null,\n} }];"
      }
