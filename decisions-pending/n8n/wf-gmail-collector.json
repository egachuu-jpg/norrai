        "jsCode": "const d = $json;\nconst esc = (s) => (s ?? '').replace(/'/g, \"''\");\nconst deadline = d.deadline ? `'${d.deadline}'` : 'NULL';\nconst draft = d.draft_reply ? `'${esc(d.draft_reply)}'` : 'NULL';\nconst ask = d.ask ? `'${esc(d.ask)}'` : 'NULL';\nreturn [{ json: {\n  thread_id: d.thread_id,\n  title_sql: `'${esc(d.title)}'`,\n  ask_sql: ask,\n  deadline_sql: deadline,\n  urgency_sql: `'${esc(d.urgency)}'`,\n  draft_sql: draft,\n} }];"
