    {
      "id": "e84ed1c2-00ae-43c3-bf58-217db1967bf0",
      "name": "Prepare Calendar Upsert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        160
      ],
      "parameters": {
        "jsCode": "const d = $json;\nconst esc = (s) => (s ?? '').replace(/'/g, \"''\");\nreturn [{ json: {\n  event_id: d.event_id,\n  title_sql: `'${esc(d.title)}'`,\n  ask_sql: `'${esc(d.ask)}'`,\n  deadline_sql: d.deadline ? `'${d.deadline}'` : 'NULL',\n  urgency_sql: `'${esc(d.urgency || 'normal')}'`,\n} }];"
      }
    },
    {
      "id": "b6764091-d7bb-406d-abc4-5bbb15403364",
      "name": "Calendar Upsert",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        800,
        160
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO cos.pending_decisions (title, ask, deadline, urgency, source, source_ref)\nVALUES ({{ $json.title_sql }}, {{ $json.ask_sql }}, {{ $json.deadline_sql }}, {{ $json.urgency_sql }}, 'calendar', '{{ $json.event_id }}')\nON CONFLICT (source, source_ref) DO UPDATE SET\n  title = EXCLUDED.title,\n  ask = EXCLUDED.ask,\n  deadline = EXCLUDED.deadline,\n  urgency = EXCLUDED.urgency,\n  updated_at = now()",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "Neon norrai"
        }
      }
    },
    {
      "id": "5fdb6767-378a-408d-914f-b34ac729522d",
      "name": "Calendar Assumption",
      "type": "n8n-nodes-base.stickyNote",
