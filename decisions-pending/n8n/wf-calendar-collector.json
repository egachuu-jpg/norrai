        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-8\",\n  \"max_tokens\": 2000,\n  \"system\": {{ JSON.stringify($('Load Calendar Prep System Prompt').first().json.system) }},\n  \"messages\": [{ \"role\": \"user\", \"content\": {{ JSON.stringify($('Build Prompt').first().json.prompt) }} }]\n}",
